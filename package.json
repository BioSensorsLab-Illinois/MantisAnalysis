{
  "name": "mantisanalysis-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "MantisAnalysis web frontend — Vite-bundled React 18 SPA. Paired with the Python package (pyproject.toml) via FastAPI.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf web/dist node_modules/.vite",
    "lint": "eslint web/src",
    "lint:fix": "eslint web/src --fix",
    "format": "prettier --write \"web/src/**/*.{js,jsx,json,css,html}\"",
    "format:check": "prettier --check \"web/src/**/*.{js,jsx,json,css,html}\""
  },
  "dependencies": {
    "dom-to-image-more": "^3.7.2",
    "plotly.js-dist-min": "^3.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prettier": "^3.8.3",
    "vite": "^5.4.11"
  },
  "engines": {
    "node": ">=20"
  }
}
